{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://extrabold.tools/schemas/dist-storage-page.schema.json",
    "title": "Storage Index product page payload",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "id",
        "name",
        "brand_id",
        "brand_name",
        "type",
        "in_open_database",
        "source_layer",
        "derived_state",
        "status_banner",
        "completeness",
        "fit_readiness",
        "trust_summary",
        "checklist",
        "missing",
        "similar_items",
        "actions",
        "links"
    ],
    "properties": {
        "id": {
            "type": "string"
        },
        "slug": {
            "type": "string"
        },
        "name": {
            "type": "string"
        },
        "brand_id": {
            "type": "string"
        },
        "brand_name": {
            "type": "string"
        },
        "type": {
            "type": "string"
        },
        "in_open_database": {
            "type": "boolean"
        },
        "source_layer": {
            "type": "string",
            "enum": [
                "open_database",
                "storage_index"
            ]
        },
        "derived_state": {
            "type": "string"
        },
        "status_banner": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "title",
                "body"
            ],
            "properties": {
                "title": {
                    "type": "string"
                },
                "body": {
                    "type": "string"
                }
            }
        },
        "completeness": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "score",
                "class",
                "segments"
            ],
            "properties": {
                "score": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 100
                },
                "class": {
                    "type": "string"
                },
                "segments": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "number"
                    }
                }
            }
        },
        "fit_readiness": {
            "type": "string"
        },
        "trust_summary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "exact_fit_eligible",
                "lines"
            ],
            "properties": {
                "exact_fit_eligible": {
                    "type": "boolean"
                },
                "lines": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "checklist": {
            "type": "object",
            "additionalProperties": {
                "type": "boolean"
            }
        },
        "missing": {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        "record": {
            "description": "Subset of source JSON safe for static UI (no $schema).",
            "type": "object",
            "additionalProperties": true
        },
        "similar_items": {
            "type": "array",
            "maxItems": 12,
            "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                    "id",
                    "name",
                    "in_open_database",
                    "completeness_score",
                    "fit_readiness"
                ],
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "in_open_database": {
                        "type": "boolean"
                    },
                    "completeness_score": {
                        "type": "integer"
                    },
                    "fit_readiness": {
                        "type": "string"
                    },
                    "page_path": {
                        "type": "string"
                    }
                }
            }
        },
        "actions": {
            "type": "object",
            "additionalProperties": {
                "type": "string",
                "format": "uri"
            }
        },
        "links": {
            "type": "object",
            "additionalProperties": {
                "type": "string",
                "format": "uri"
            }
        }
    }
}
