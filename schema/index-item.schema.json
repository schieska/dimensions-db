{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://extrabold.tools/schemas/index-item.schema.json",
    "title": "Dimensions DB - Storage Index Item",
    "description": "Catalogue-first records that may lack full geometry. Not part of the open DB export until promoted to src/items.",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "id",
        "name",
        "brand",
        "type",
        "sources",
        "provenance"
    ],
    "properties": {
        "$schema": {
            "type": "string"
        },
        "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_\\-\\.]*[a-z0-9]$"
        },
        "slug": {
            "type": "string",
            "minLength": 3,
            "maxLength": 120,
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 140
        },
        "description": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "string",
                    "maxLength": 500
                }
            ]
        },
        "brand": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
        },
        "type": {
            "type": "string",
            "enum": [
                "container",
                "drawer",
                "furniture",
                "component",
                "insert",
                "tray"
            ]
        },
        "sources": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "https://extrabold.tools/schemas/item.schema.json#/$defs/source"
            }
        },
        "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "method",
                "source_name"
            ],
            "properties": {
                "batch_id": {
                    "type": "string",
                    "maxLength": 80
                },
                "method": {
                    "type": "string",
                    "enum": [
                        "catalogue-import",
                        "manual",
                        "community",
                        "retailer-scrape",
                        "other"
                    ]
                },
                "source_name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 120
                },
                "source_url": {
                    "$ref": "https://extrabold.tools/schemas/common.schema.json#/$defs/url"
                },
                "retrieved_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "transform_version": {
                    "type": "string",
                    "maxLength": 80
                },
                "source_hash": {
                    "type": "string",
                    "maxLength": 200
                },
                "licence_note": {
                    "type": "string",
                    "maxLength": 500
                }
            }
        },
        "inner_size": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "https://extrabold.tools/schemas/common.schema.json#/$defs/size"
                }
            ]
        },
        "outer_size": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "https://extrabold.tools/schemas/common.schema.json#/$defs/size"
                }
            ]
        },
        "images": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "array",
                    "items": {
                        "$ref": "https://extrabold.tools/schemas/item.schema.json#/$defs/imageRef"
                    }
                }
            ]
        },
        "identifiers": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "$ref": "https://extrabold.tools/schemas/item.schema.json#/$defs/identifiers"
                }
            ]
        },
        "measurements": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "https://extrabold.tools/schemas/item.schema.json#/$defs/measurementEntry"
                    }
                }
            ]
        },
        "evidence": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/indexEvidenceEntry"
                    }
                }
            ]
        },
        "collections": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "minLength": 2,
                        "maxLength": 80
                    },
                    "uniqueItems": true
                }
            ]
        },
        "variant": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "color": {
                            "type": "string",
                            "maxLength": 40
                        },
                        "region": {
                            "type": "string",
                            "maxLength": 20
                        },
                        "revision": {
                            "type": "string",
                            "maxLength": 40
                        }
                    }
                }
            ]
        },
        "duplicate_of": {
            "anyOf": [
                {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 120
                },
                {
                    "type": "null"
                }
            ]
        },
        "deprecated": {
            "anyOf": [
                {
                    "type": "boolean"
                },
                {
                    "type": "null"
                }
            ]
        },
        "replaced_by": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "disputed_fields": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "maxLength": 120
                    },
                    "uniqueItems": true
                }
            ]
        },
        "verification_state": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "string",
                    "enum": [
                        "pending",
                        "community_submitted",
                        "community_verified",
                        "official_verified",
                        "disputed",
                        "deprecated",
                        "merged_duplicate",
                        "rejected"
                    ]
                }
            ]
        },
        "status": {
            "anyOf": [
                {
                    "type": "null"
                },
                {
                    "type": "string",
                    "enum": [
                        "draft",
                        "community",
                        "verified"
                    ]
                }
            ]
        },
        "updated_at": {
            "anyOf": [
                {
                    "$ref": "https://extrabold.tools/schemas/common.schema.json#/$defs/isoDate"
                },
                {
                    "type": "null"
                }
            ]
        }
    },
    "$defs": {
        "indexEvidenceEntry": {
            "type": "object",
            "additionalProperties": false,
            "required": [
                "id",
                "kind"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "minLength": 2,
                    "maxLength": 80,
                    "pattern": "^[a-zA-Z0-9_\\-]+$"
                },
                "kind": {
                    "type": "string",
                    "enum": [
                        "manufacturer",
                        "manual",
                        "community_photo",
                        "retailer_page",
                        "video",
                        "community_confirmation",
                        "other"
                    ]
                },
                "url": {
                    "$ref": "https://extrabold.tools/schemas/common.schema.json#/$defs/url"
                },
                "supports": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "pattern": "^/"
                    },
                    "minItems": 1,
                    "uniqueItems": true
                },
                "confidence": {
                    "type": "string",
                    "enum": [
                        "low",
                        "medium",
                        "high"
                    ]
                },
                "note": {
                    "type": "string",
                    "maxLength": 240
                }
            }
        }
    }
}
